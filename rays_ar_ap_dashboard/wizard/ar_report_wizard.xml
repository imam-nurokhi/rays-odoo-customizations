<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_rays_ar_report" model="ir.actions.act_window">
        <field name="name">AR Dashboard - Piutang Premi &amp; Diskon</field>
        <field name="res_model">rays.ar.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_date_from': False, 'default_date_to': False}</field>
    </record>

    <record id="view_rays_ar_report_form" model="ir.ui.view">
        <field name="name">rays.ar.report.form</field>
        <field name="model">rays.ar.report</field>
        <field name="arch" type="xml">
            <form string="AR Dashboard - Piutang Premi &amp; Diskon">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span class="text-primary">&#128197; AR Dashboard</span>
                            <small class="text-muted ms-2">Piutang Premi &amp; Diskon</small>
                        </h1>
                    </div>

                    <!-- Filter Section -->
                    <group string="&#128269; Filter Laporan" col="4">
                        <field name="date_from" string="Dari Tanggal"/>
                        <field name="date_to" string="Sampai Tanggal"/>
                        <field name="category" string="Kategori"/>
                        <field name="payment_state" string="Status Bayar"/>
                        <field name="partner_id" string="Customer"/>
                        <field name="currency_id" string="Mata Uang"/>
                    </group>

                    <!-- Summary Section (shown after report generated) -->
                    <group string="&#128200; Ringkasan AR" invisible="total_premi == 0 and total_diskon == 0">
                        <group string="PREMI" col="2">
                            <field name="count_premi" string="Jumlah Invoice"/>
                            <field name="total_premi" string="Total PREMI (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="text-success fw-bold"/>
                        </group>
                        <group string="DISKON" col="2">
                            <field name="count_diskon" string="Jumlah Credit Note"/>
                            <field name="total_diskon" string="Total DISKON (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="text-danger fw-bold"/>
                        </group>
                        <group string="NET AR" col="2">
                            <field name="total_net" string="Net AR Outstanding (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="fw-bold"/>
                        </group>
                    </group>

                    <!-- Download section (shown after Excel generated) -->
                    <group invisible="not excel_file">
                        <field name="excel_file" invisible="1"/>
                        <field name="excel_filename" invisible="1"/>
                        <div class="alert alert-success" role="alert">
                            <strong>&#9989; File Excel siap!</strong>
                            File <em><field name="excel_filename" readonly="1" nolabel="1" class="d-inline"/></em>
                            telah digenerate. Klik <strong>Download Excel</strong> untuk mengunduh.
                        </div>
                    </group>
                </sheet>

                <footer>
                    <button name="action_view_report" string="&#128200; Lihat Ringkasan"
                            type="object" class="btn-secondary"/>
                    <button name="action_export_excel" string="&#128229; Export &amp; Download Excel"
                            type="object" class="btn-primary"/>
                    <button string="Tutup" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
