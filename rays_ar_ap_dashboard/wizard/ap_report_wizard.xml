<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_rays_ap_report" model="ir.actions.act_window">
        <field name="name">AP Dashboard - Hutang Premi &amp; Brokerage</field>
        <field name="res_model">rays.ap.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_rays_ap_report_form" model="ir.ui.view">
        <field name="name">rays.ap.report.form</field>
        <field name="model">rays.ap.report</field>
        <field name="arch" type="xml">
            <form string="AP Dashboard - Hutang Premi &amp; Brokerage">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span class="text-danger">&#128197; AP Dashboard</span>
                            <small class="text-muted ms-2">Hutang Premi &amp; Brokerage</small>
                        </h1>
                    </div>

                    <!-- Filter Section -->
                    <group string="&#128269; Filter Laporan" col="4">
                        <field name="date_from" string="Dari Tanggal"/>
                        <field name="date_to" string="Sampai Tanggal"/>
                        <field name="category" string="Kategori"/>
                        <field name="payment_state" string="Status Bayar"/>
                        <field name="partner_id" string="Vendor/Asuransi"/>
                        <field name="currency_id" string="Mata Uang"/>
                    </group>

                    <!-- Summary Section -->
                    <group string="&#128200; Ringkasan AP" invisible="total_premi == 0 and total_brokerage == 0">
                        <group string="PREMI - Hutang ke Asuransi" col="2">
                            <field name="count_premi" string="Jumlah Bill"/>
                            <field name="total_premi" string="Total Hutang Premi (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="text-danger fw-bold"/>
                        </group>
                        <group string="BROKERAGE - Komisi" col="2">
                            <field name="count_brokerage" string="Jumlah Invoice Brokerage"/>
                            <field name="total_brokerage" string="Total Brokerage (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="text-success fw-bold"/>
                        </group>
                        <group string="NET AP" col="2">
                            <field name="total_net" string="Net AP Outstanding (IDR)"
                                   widget="monetary"
                                   options="{'currency_field': False}"
                                   class="fw-bold"/>
                        </group>
                    </group>

                    <!-- Download section -->
                    <group invisible="not excel_file">
                        <field name="excel_file" invisible="1"/>
                        <field name="excel_filename" invisible="1"/>
                        <div class="alert alert-success" role="alert">
                            <strong>&#9989; File Excel siap!</strong>
                            File <em><field name="excel_filename" readonly="1" nolabel="1" class="d-inline"/></em>
                            telah digenerate. Klik <strong>Download Excel</strong> untuk mengunduh.
                        </div>
                    </group>
                </sheet>

                <footer>
                    <button name="action_view_report" string="&#128200; Lihat Ringkasan"
                            type="object" class="btn-secondary"/>
                    <button name="action_export_excel" string="&#128229; Export &amp; Download Excel"
                            type="object" class="btn-primary"/>
                    <button string="Tutup" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
